generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id           Int       @id @default(autoincrement())
  name         String
  category     String
  menus        String[]
  price        String
  priceLevel   Int
  rating       Float     @default(0)
  lat          Float
  lng          Float
  hours        String?
  phone        String?
  satiety      String
  speed        String
  occasion     String    @default("meal")
  naverUrl     String?
  naverPlaceId String?
  isBase       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  checkins     Checkin[]
}

model Checkin {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  username     String
  date         String
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, username, date])
}
